{
    // Full path to the shell executable, such as C:/Git/bin/bash.exe,
    // or only the executable name if the executable is on the path.
    "Shell Path": "zsh",

    // Comma-separated list of command line arguments for the shell,
    // for example ["--login", "--interactive"].
    "Shell Arguments": ["--login"],

    // The number of columns that the terminal has.
    "cols": 80,

    // The number of rows that the terminal has.
    "rows": 24,

    // See https://xtermjs.org/docs/api/terminal/interfaces/iterminaloptions/
    // for a description of the fields and their values.
    "options": {
        "allowProposedApi": false,
        "allowTransparency": false,
        "altClickMovesCursor": true,
        "convertEol": false,
        "cursorBlink": false,
        "cursorInactiveStyle": "outline",
        "cursorStyle": "block",
        "cursorWidth": 1,
        "customGlyphs": true,
        "disableStdin": false,
        "documentOverride": null,
        "drawBoldTextInBrightColors": true,
        "fastScrollSensitivity": 5,
        "fontFamily": "monospace",
        "fontSize": 11,
        "fontWeight": "normal",
        "fontWeightBold": "bold",
        "ignoreBracketedPasteMode": false,
        "letterSpacing": 0,
        "lineHeight": 1,
        "linkHandler": null,
        "logLevel": "info",
        "logger": null,
        "macOptionClickForcesSelection": false,
        "macOptionIsMeta": false,
        "minimumContrastRatio": 1,
        "overviewRuler": {},
        "reflowCursorLine": false,
        "rescaleOverlappingGlyphs": false,
        "rightClickSelectsWord": false,
        "screenReaderMode": false,
        "scrollOnEraseInDisplay": false,
        "scrollOnUserInput": true,
        "scrollSensitivity": 1,
        "scrollback": 1000,
        "smoothScrollDuration": 0,
        "tabStopWidth": 8,
        "theme": {},
        "windowOptions": {},
        "windowsPty": {},
        "wordSeparator": " ()[]{}',\"`"
    }
}